{
  "name": "pi-recurse",
  "version": "0.1.0",
  "description": "Recursive agent extension for Pi — spawn subagents programmatically with depth guardrails",
  "type": "module",
  "author": "Tom X Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/pi-recurse.git"
  },
  "homepage": "https://github.com/monotykamary/pi-recurse#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/pi-recurse/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "recursion",
    "subagent",
    "parallel",
    "divide-and-conquer"
  ],
  "files": [
    "*.ts",
    "*.js",
    "*.d.ts",
    "lib/**",
    "tests/**",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "release": "standard-version",
    "release:dry-run": "standard-version --dry-run",
    "postinstall": "simple-git-hooks"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.3",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "standard-version": "^9.5.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.x",
    "@mariozechner/pi-tui": "^0.x",
    "@sinclair/typebox": "^0.x"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run typecheck && npm run test",
    "commit-msg": "npx commitlint --edit ${1}"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
